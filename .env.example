# Arabic Document Processor - Environment Configuration
# Copy this file to .env and adjust values as needed

# Vision model API endpoint (for Docker: use service name)
VISION_URL=http://vision-engine:8000/v1/chat/completions

# Text model API endpoint (for Docker: use service name)
TEXT_URL=http://text-engine:8001/v1/chat/completions

# Directory for uploaded image files
UPLOAD_DIR=/data/uploads

# SQLite database path
DB_PATH=/data/jobs.db
